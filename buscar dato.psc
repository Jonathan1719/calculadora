Algoritmo buscar
	definir arreglo Como Entero
	dimension arreglo[5]
	arreglo[1]=2
	arreglo[2]=4
	arreglo[3]=6
	arreglo[4]=8
	arreglo[5]=10
	leer numero
	Para  i=1 Hasta 5 Hacer
		si arreglo[i]= numero Entonces
			Mostrar "numero encontrato"
		SiNo
			Mostrar "no se ha encontrado"
		FinSi
		
	FinPara
FinAlgoritmo
